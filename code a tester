#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

#define MAX_TEXT 256
#define MAX_Q 50
#define PASSWORD_ADMIN "amine" // Mot de passe demandé : amine

typedef struct {
    char enonce[MAX_TEXT];
    char props[4][MAX_TEXT];
    char solution[10];
} Question;

// --- Sécurité : Vidage du tampon clavier ---
void vider_tampon() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

