/**
 * Charge un QCM depuis un fichier binaire sauvegardé par le mode Enseignant
 */
QCM* charger_qcm(const char* nom_fichier) {
    FILE* fichier = fopen(nom_fichier, "rb");
    if (fichier == NULL) {
        return NULL;
    }

    QCM* qcm = malloc(sizeof(QCM));
    if (qcm == NULL) {
        fclose(fichier);
        return NULL;
    }

    // Lecture de l'intégralité de la structure QCM depuis le fichier
    fread(qcm, sizeof(QCM), 1, fichier);
    fclose(fichier);
    return qcm;
}

/**
 * Gère le déroulement de l'examen et la navigation entre les questions
 */
void lancer_qcm(QCM* qcm) {
    // Tableau pour stocker les réponses de l'étudiant 
    // reponses_eleve[i][j] = 1 si l'élève a coché la réponse j de la question i, sinon 0
    int reponses_eleve[MAX_QUESTIONS][MAX_ANSWERS] = {0};
    int question_actuelle = 0;
    char navigation;
    
    // Enregistrement de l'heure de début pour la limite de temps
    time_t temps_debut = time(NULL);

    printf("\n>>> Debut du QCM : %s (Matiere : %s) <<<\n", qcm->nom, qcm->matiere);
    if (qcm->limite_temps > 0) {
        printf("[ATTENTION] Vous avez une limite de temps de %d secondes pour ce QCM.\n", qcm->limite_temps);
    }
    printf("Regles : Entrez le numero de la reponse pour la cocher/decocher.\n");
    printf("Navigation : 'P' pour Précédent, 'S' pour Suivant, 'T' pour Terminer et valider.\n\n");

    while (question_actuelle < qcm->nb_questions) {
        // Vérification du temps écoulé
        if (qcm->limite_temps > 0) {
            time_t temps_actuel = time(NULL);
            if (difftime(temps_actuel, temps_debut) > qcm->limite_temps) {
                printf("\n[TEMPS ECOULE !] Le temps imparti est depasse. Correction automatique.\n");
                break; 
            }
        }

        Question q = qcm->questions[question_actuelle];
        printf("\n--- Question %d/%d (%.2f pts) ---\n", question_actuelle + 1, qcm->nb_questions, q.points);
        printf("%s\n", q.enonce);

        // Affichage des choix possibles
        for (int i = 0; i < q.nb_reponses; i++) {
            // Affiche [X] si coché, [ ] sinon
            char coche = reponses_eleve[question_actuelle][i] ? 'X' : ' ';
            printf("  %d. [%c] %s\n", i + 1, coche, q.reponses[i].texte);
        }

        // Menu d'action dynamique
        printf("\nVotre action (Chiffre pour cocher | 'S'=Suivant | 'P'=Precedent | 'T'=Terminer) : ");
        scanf(" %c", &navigation);

        if (navigation >= '1' && navigation <= '9') {
            int choix_reponse = navigation - '1'; // Conversion char vers index int
            if (choix_reponse < q.nb_reponses) {
                if (qcm->reponses_multiples) {
                    // Mode réponses multiples : on inverse l'état (on coche/décoche)
                    reponses_eleve[question_actuelle][choix_reponse] = !reponses_eleve[question_actuelle][choix_reponse];
                } else {
                    // Mode réponse unique : on décoche tout et on coche la nouvelle
                    for (int i = 0; i < q.nb_reponses; i++) reponses_eleve[question_actuelle][i] = 0;
                    reponses_eleve[question_actuelle][choix_reponse] = 1;
                }
            }
        } 
        else if (navigation == 'S' || navigation == 's') {
            // Vérification du mode séquentiel : a-t-il répondu à au moins une option ?
            int a_repondu = 0;
            for (int i = 0; i < q.nb_reponses; i++) {
                if (reponses_eleve[question_actuelle][i] == 1) a_repondu = 1;
            }

            if (qcm->mode_sequentiel && !a_repondu) {
                printf("[Bloque] Le mode sequentiel est actif. Vous devez repondre avant de passer.\n");
            } else {
                question_actuelle++;
            }
        } 
        else if (navigation == 'P' || navigation == 'p') {
            // Autoriser le retour en arrière uniquement si le mode séquentiel ne l'interdit pas
            if (qcm->mode_sequentiel) {
                printf("[Bloque] Mode sequentiel actif. Retour en arriere impossible.\n");
            } else if (question_actuelle > 0) {
                question_actuelle--;
            } else {
                printf("Vous etes deja a la premiere question.\n");
            }
        } 
        else if (navigation == 'T' || navigation == 't') {
            // L'étudiant décide de terminer le QCM avant la fin des questions
            char confirmation;
            printf("Etes-vous sur de vouloir terminer et soumettre vos reponses ? (O/N) : ");
            scanf(" %c", &confirmation);
            if (confirmation == 'O' || confirmation == 'o') {
                break;
            }
        }
    }

    // 4. Évaluation et calcul de la note finale
    evaluer_qcm(qcm, reponses_eleve, temps_debut);
}

/**
 * Compare les réponses, applique le barème (points négatifs) et ramène la note sur 20.
 */
void evaluer_qcm(QCM* qcm, int reponses_eleve[MAX_QUESTIONS][MAX_ANSWERS], time_t temps_debut) {
    float total_points_eleve = 0.0;
    float total_points_qcm = 0.0;

    printf("\n=========================================\n");
    printf("             CORRECTION & RÉSULTATS      \n");
    printf("=========================================\n");

    for (int i = 0; i < qcm->nb_questions; i++) {
        Question q = qcm->questions[i];
        total_points_qcm += q.points;
        int question_sans_faute = 1;
        int aucune_case_cochee = 1;

        for (int j = 0; j < q.nb_reponses; j++) {
            if (reponses_eleve[i][j] == 1) aucune_case_cochee = 0;

            // Si l'élève s'est trompé (a coché une fausse ou n'a pas coché une vraie)
            if (reponses_eleve[i][j] != q.reponses[j].est_correcte) {
                question_sans_faute = 0;
            }
        }

        if (question_sans_faute) {
            // La question est parfaitement juste
            total_points_eleve += q.points;
            printf("Question %d : Juste (+%.2f pts)\n", i + 1, q.points);
        } else {
            // Gestion des points négatifs si paramétré par l'enseignant
            if (qcm->points_negatifs && !aucune_case_cochee) {
                // On retire la moitié de la valeur de la question par exemple
                float penalite = q.points / 2.0;
                total_points_eleve -= penalite;
                printf("Question %d : Fausse (-%.2f pts de penalite)\n", i + 1, penalite);
            } else {
                printf("Question %d : Fausse ou non repondue (0.00 pt)\n", i + 1);
            }
        }
    }

    // Sécurité pour éviter les notes globales négatives
    if (total_points_eleve < 0) total_points_eleve = 0;

    // Calcul de la note finale ramenée sur 20 points (Règle de trois)
    float note_sur_20 = (total_points_eleve / total_points_qcm) * 20.0;
    time_t temps_fin = time(NULL);

    printf("\n-----------------------------------------\n");
    printf("Duree de l'epreuve : %.0f secondes\n", difftime(temps_fin, temps_debut));
    printf("Points obtenus     : %.2f / %.2f\n", total_points_eleve, total_points_qcm);
    printf("NOTE FINALE        : ** %.2f / 20 **\n", note_sur_20);
    printf("=========================================\n");
}
