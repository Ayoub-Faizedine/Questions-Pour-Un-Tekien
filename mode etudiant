#include <stdio.h>

void Fonction_Mode_Etudiant() {
    int difficulte; // On déclare une variable entière pour le choix

    printf("\n--- Bienvenue dans le Mode Etudiant ---\n");
    printf("Veuillez choisir votre niveau de difficulte :\n");
    printf("1. Mode Facile\n");
    printf("2. Mode Intermediaire\n");
    printf("3. Mode Difficile\n");
    
    printf("Votre choix : ");
    
    // %d indique qu'on attend un entier (int)
    // &difficulte est l'adresse où stocker la valeur
    if (scanf("%d", &difficulte) != 1) {
        printf("Erreur : Veuillez entrer un nombre.\n");
        // Vide le tampon pour éviter une boucle infinie si utilisé dans un menu
        while (getchar() != '\n'); 
        return;
    }

    // Utilisation d'un switch pour tester les différentes valeurs
    switch (difficulte) {
        case 1:
            printf("Lancement du quiz en mode Facile...\n");
            break;
        case 2:
            printf("Lancement du quiz en mode Intermediaire...\n");
            break;
        case 3:
            printf("Lancement du quiz en mode Difficile...\n");
            break;
        default:
            printf("Choix de difficulte invalide.\n");
            break;
    }
}
