voici ce qu'a fait mon collegue #include <stdio.h>
#include <stdlib.h>
#include <string.h>

/* --- Structure pour organiser les données d'une question --- */
struct Question {
    char texte[200];      // L'énoncé de la question
    char choix[4][100];   // Tableau de 4 chaînes pour les options de réponse
    int reponse_correcte; // Le numéro de la bonne réponse (1, 2, 3 ou 4)
    float points;         // Le nombre de points que rapporte cette question
};

int main() {
    // Déclaration des variables nécessaires
    char nomFichier[50];
    int nbQuestions, i, reponseUser;
    float noteTotale = 0, pointsMax = 0;
    int modeSequentiel, pointsNegatifs, difficulte;

    printf("=== MODE ETUDIANT ===\n");
    printf("Entrez le nom du fichier QCM a charger (ex: examen.txt) : ");
    scanf("%s", nomFichier);

    // --- Ouverture du fichier en mode lecture ("r") ---
    FILE *fichier = fopen(nomFichier, "r");
    if (fichier == NULL) {
        printf("Erreur : Fichier introuvable. Verifiez le nom.\n");
        return 1; // Quitte le programme si le fichier n'existe pas
    }

    /* 
       1. LECTURE DES PARAMETRES DU QCM 
       L'enseignant a sauvegardé ces informations en haut du fichier.
    */
    // On lit : Difficulté (1-3), Mode Séquentiel (0/1), Points Négatifs (0/1)
    fscanf(fichier, "%d %d %d", &difficulte, &modeSequentiel, &pointsNegatifs);
    // On lit le nombre de questions total dans le fichier
    fscanf(fichier, "%d", &nbQuestions);

    // Création d'un tableau de structures pour stocker toutes les questions
    struct Question q[nbQuestions];

    /* 
       2. CHARGEMENT DES QUESTIONS DEPUIS LE FICHIER 
    */
    for (i = 0; i < nbQuestions; i++) {
        fgetc(fichier); // Nettoyage du caractère "entrée" resté dans le buffer
        
        // On récupère l'énoncé de la question (toute la ligne)
        fgets(q[i].texte, 200, fichier); 
        
        // On récupère les 4 mots/options possibles
        fscanf(fichier, "%s %s %s %s", q[i].choix[0], q[i].choix[1], q[i].choix[2], q[i].choix[3]);
        
        // On récupère l'indice de la bonne réponse et les points attribués
        fscanf(fichier, "%d %f", &q[i].reponse_correcte, &q[i].points);
    }
    fclose(fichier); // Fermeture du fichier car tout est chargé en mémoire

    /* 
       3. DEROULEMENT DU TEST 
    */
    printf("\n--- DEBUT DU TEST (Niveau: %d) ---\n", difficulte);
    
    for (i = 0; i < nbQuestions; i++) {
        // Affichage de la question et des options
        printf("\nQuestion %d : %s", i + 1, q[i].texte);
        printf("1) %s\n2) %s\n3) %s\n4) %s\n", q[i].choix[0], q[i].choix[1], q[i].choix[2], q[i].choix[3]);
        
        // Demande de la réponse à l'étudiant
        printf("Votre choix (1-4) : ");
        scanf("%d", &reponseUser);

        // Cumul des points maximums possibles pour le calcul final
        pointsMax += q[i].points;

        // --- Vérification de la réponse ---
        if (reponseUser == q[i].reponse_correcte) {
            printf(">> Correct !\n");
            noteTotale += q[i].points; // Ajout des points
        } else {
            printf(">> Mauvaise reponse.\n");
            // Si l'enseignant a activé les points négatifs
            if (pointsNegatifs == 1) {
                printf("Malus applique.\n");
                noteTotale -= (q[i].points * 0.5); // On retire 50% de la valeur de la question
            }
        }
    }

    /* 
       4. CALCUL ET AFFICHAGE DE LA NOTE FINALE 
    */
    // Règle de trois : (Points obtenus / Points Max) * 20
    float noteSur20 = (noteTotale / pointsMax) * 20;
    
    // Sécurité pour ne pas avoir de note en dessous de zéro à cause des malus
    if (noteSur20 < 0) noteSur20 = 0;

    printf("\n==============================");
    printf("\n   NOTE FINALE : %.2f / 20", noteSur20);
    printf("\n==============================\n");

    return 0;
}
